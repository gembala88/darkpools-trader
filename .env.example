# === Mode (mirror of user-config; user-config is source of truth) ===
TRADING_MODE=dry_run

# === LLM (OpenAI-compatible; NVIDIA NIM default) ===
ENABLE_LLM=true
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_API_KEY=                 # NVIDIA key (prefix nvapi-). Get at build.nvidia.com
LLM_MODEL=meta/llama-3.3-70b-instruct
LLM_TIMEOUT_MS=60000
LLM_CANDIDATE_PICK_COUNT=5
LLM_CANDIDATE_MAX_AGE_MS=600000

# === Signal server (Phase 2; DISABLED by default) ===
SIGNAL_SERVER_URL=https://api.thecharon.xyz/api
SIGNAL_SERVER_KEY=           # REGENERATE — the old one was exposed in chat
SIGNAL_POLL_MS=30000

# === Solana RPC (Helius) — regenerate a FRESH key, do not reuse other projects ===
HELIUS_API_KEY=
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=

# === GMGN enrichment (set GMGN_ENABLED=false to skip -> falls back to Jupiter) ===
GMGN_ENABLED=true
GMGN_API_KEY=
GMGN_REQUEST_DELAY_MS=2500
GMGN_MAX_RETRIES=2
GMGN_CACHE_TTL_MS=300000

# === Jupiter (price/quote; swap used only in live) ===
JUPITER_API_KEY=
JUPITER_SWAP_BASE_URL=https://api.jup.ag/swap/v2

# === Telegram (Phase 8) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_CHANNEL_ID=
TELEGRAM_TOPIC_ID=

# === Database ===
DB_PATH=./darkpools.sqlite

# === Wallet (LIVE ONLY) — leave BLANK, never commit, never paste in chat ===
SOLANA_PRIVATE_KEY=
LIVE_MIN_SOL_RESERVE=0.05
